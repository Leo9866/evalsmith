# EvalSmith single-node trial deployment defaults

EVALSMITH_GATEWAY_PORT=8080
EVALSMITH_TRACE_PORT=8001
EVALSMITH_EVAL_PORT=8002
EVALSMITH_DATASET_PORT=8003
EVALSMITH_AUTH_PORT=8004
EVALSMITH_ANNOTATION_PORT=8005
EVALSMITH_MONITOR_PORT=8006
EVALSMITH_MONITOR_WORKER_POLL_INTERVAL_SECONDS=60
EVALSMITH_MONITOR_WORKER_TRACE_PAGE_SIZE=25

EVALSMITH_PG_PORT=15432
EVALSMITH_CH_HTTP_PORT=18123
EVALSMITH_CH_NATIVE_PORT=19000
EVALSMITH_KAFKA_PORT=19092
EVALSMITH_REDIS_PORT=26379
EVALSMITH_MINIO_API_PORT=19100
EVALSMITH_MINIO_CONSOLE_PORT=19101

EVALSMITH_PG_USER=evalsmith
EVALSMITH_PG_PASSWORD=__REDACTED_SECRET__
EVALSMITH_PG_DATABASE=evalsmith
EVALSMITH_PG_SCHEMA=public

EVALSMITH_CLICKHOUSE_DATABASE=evalsmith
EVALSMITH_CLICKHOUSE_USER=default
EVALSMITH_CLICKHOUSE_PASSWORD=__REDACTED_SECRET__

EVALSMITH_MINIO_ROOT_USER=evalsmith
EVALSMITH_MINIO_ROOT_PASSWORD=__REDACTED_SECRET__
EVALSMITH_MINIO_BUCKET=trace-payloads

EVALSMITH_INTERNAL_TOKEN=__REDACTED_SECRET__
EVALSMITH_SECRET_KEY=__REDACTED_SECRET__
EVALSMITH_GOPROXY=https://proxy.golang.org,direct
EVALSMITH_PIP_INDEX_URL=https://pypi.org/simple
EVALSMITH_NPM_REGISTRY=https://registry.npmjs.org/

# Local Docker Compose trial login. Disable this or override the login phrase
# before exposing the stack outside your machine.
EVALSMITH_DEMO_USER_ENABLED=true
EVALSMITH_DEMO_USER_EMAIL=demo@evalsmith.local
EVALSMITH_DEMO_USER_NAME="EvalSmith Demo"
# EVALSMITH_DEMO_USER_PASSWORD=__REDACTED_SECRET__

# Optional image overrides for restricted networks or local caches.
EVALSMITH_PYTHON_BASE_IMAGE=python:3.12-slim
EVALSMITH_GOLANG_BASE_IMAGE=golang:1.24-alpine
EVALSMITH_ALPINE_BASE_IMAGE=alpine:3.21
EVALSMITH_NODE_BASE_IMAGE=node:22-alpine
EVALSMITH_NGINX_BASE_IMAGE=nginx:1.27-alpine
EVALSMITH_BUILDPLATFORM=
EVALSMITH_TARGETPLATFORM=
EVALSMITH_POSTGRES_IMAGE=postgres:15-alpine
EVALSMITH_CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:24.3
EVALSMITH_KAFKA_IMAGE=apache/kafka:3.9.0
EVALSMITH_REDIS_IMAGE=redis:7-alpine
EVALSMITH_MINIO_IMAGE=minio/minio:latest
